# Vitally REST API credentials.
# Get the API key from Vitally → Settings → Integrations → Vitally REST API.

VITALLY_API_SUBDOMAIN=your-subdomain   # e.g. "wiseair" — used for the US data center base URL only
VITALLY_API_KEY=your_api_key_here      # Secret token; if unset or left as the placeholder, the server runs in demo mode
VITALLY_DATA_CENTER=US                 # US | EU. EU uses a single shared host (rest.vitally-eu.io)
